  font-weight: 600;
  src: url('/assets/fonts/public-sans-v21-latin-600.woff2') format('woff2');
}
@font-face {
  font-display: swap;
  font-family: 'Public Sans';
  font-style: normal;
  font-weight: 700;
  src: url('/assets/fonts/public-sans-v21-latin-700.woff2') format('woff2');
}
@font-face {
  font-display: swap;
