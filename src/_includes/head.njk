<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<!-- METADATA-->
<meta name="generator" content="Eleventy v3.0.0">
<meta name="author" content="Partijgedrag">

<!-- CONTENT-->
<title>Partijgedrag België - {{ title }}</title>
<meta name="description" content="{{ description or title }}">

<!-- SEARCH AND INDEXING -->
<meta name="robots" content="index,follow">
<meta name="google" content="nositelinkssearchbox">
<link rel="canonical" href="https://partijgedrag.be{{ page.url }}" />

<!-- STRUCTURED DATA (JSON-LD) -->
{%- from "components/json-ld.njk" import jsonLd -%}
{% set organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://partijgedrag.be/#organization",
    "name": "Partijgedrag",
    "url": "https://partijgedrag.be/",
    "logo": "https://partijgedrag.be/web-app-manifest-512x512.png",
    "sameAs": [
        "https://bsky.app/profile/partijgedrag.be",
        "https://instagram.com/partijgedragbe"
    ]
} %}
{{ jsonLd(organizationSchema) }}
{% set websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://partijgedrag.be/#website",
    "url": "https://partijgedrag.be/",
    "name": "Partijgedrag.be",
    "description": "Volg het stemgedrag van Belgische partijen en parlementsleden in de Kamer van Volksvertegenwoordigers.",
    "inLanguage": ["nl", "fr", "en"],
    "publisher": { "@id": "https://partijgedrag.be/#organization" }
} %}
{{ jsonLd(websiteSchema) }}
<!--
  Note: no WebSite `potentialAction` (SearchAction) is included on purpose.
  Adding one is what makes Google eligible to show the sitelinks search box,
  which this site explicitly opts out of above via <meta name="google" content="nositelinkssearchbox">.
-->

<!-- OPEN GRAPH PROTOCOL -->
<meta property="og:url" content="https://partijgedrag.be{{ page.url }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description or title }}">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:locale" content="nl_BE">
<meta property="og:site_name" content="Partijgedrag">
{% ogImage "./og-image.og.njk", { title: title } %}

<!-- TWITTER -->
<meta name="twitter:title" content="{{ title + " · Partijgedrag" }}">
<meta name="twitter:card" content="summary">
<meta name="twitter:description" content="{{ description or title }}">

<!-- ICONS -->
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="Partijgedrag" />
<link rel="manifest" href="/site.webmanifest" />

<!-- COLORS-->
<meta name="theme-color" content="#ffffff">

<!-- STYLING -->
{% set css %}
    {% include "styles.njk" %}
{% endset %}

<style>{{ css | safe }}</style>

<!-- FONTS -->
