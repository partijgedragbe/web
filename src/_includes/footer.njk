<script>
async function handleSubscribe(event) {
    event.preventDefault();
    const email = document.getElementById("newsletter-email").value;
    const status = document.getElementById("subscribe-status");
    const btn = event.target.querySelector("button");

    btn.disabled = true;
    btn.textContent = "…";
    status.textContent = "";

    try {
        const res = await fetch("https://www.rumicat.com/api/subscribe/partijgedragbe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
        });

        if (res.ok) {
            status.textContent = "✓ Bevestigingsmail verzonden!";
            status.style.borderRadius = "0.4rem";
            status.style.padding = "0.2rem 0.4rem";
            status.style.color = "var(--color-on-positive)";
            status.style.backgroundColor = "var(--color-positive)";
            event.target.reset();
        } else {
            status.textContent = "Er ging iets mis. Probeer opnieuw.";
            status.style.borderRadius = "0.4rem";
            status.style.padding = "0.2rem 0.4rem";
            status.style.color = "var(--color-on-negative)";
            status.style.backgroundColor = "var(--color-negative)";
        }
    } catch {
        status.textContent = "Geen verbinding. Probeer opnieuw.";
        status.style.color = "red";
    } finally {
        btn.disabled = false;
        btn.textContent = "Inschrijven";
    }
}
</script>
