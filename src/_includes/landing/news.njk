<!-- COMPONENTS -->
{%- from "components/plenary-news-item.njk" import plenaryNewsItem -%}

{% set plenaries = meetings.meetings | activePlenaries %}
{% set plenary = plenaries[0] %}
{% set plenary2 = plenaries[1] %}
{% set commission = (meetings.meetings | filter("type", "commission"))[0] %}

{% set attendance = plenary.attendance %}
{% set attendance2 = plenary2.attendance %}

<h2 data-i18n="newsTitle">Nieuws uit De Kamer</h2>
<p data-i18n="newsSubtitle">Bekijk recente plenaire vergaderingen en commissievergaderingen.</p>

<!-- NEWS CARDS -->
<div class="swipeable-row">

    {{ plenaryNewsItem({ meeting: plenary, sessionId: 56 }) }}
    {{ plenaryNewsItem({ meeting: plenary2, sessionId: 56 }) }}

   <!-- COMMISSION NEWS ITEM -->
    <div class="swipeable-item card" style="height: fit-content;">
        <div class="card-section">
            <div class="category align-items:center flex-row">
                <span>Nieuwe commissievergadering op {{ (commission.date) | date }}</span>
            </div>
            <div class="padding-tight">
                {% set ctype = commission.commission_type | default('', true) %}
                {% set c = commissions[ctype] or {} %}
                <p>{{ c.name or ctype }}</p>
                <p>Voorgezeten door <a href="/members/{{ commission.chairs[0].name | slugify }}/">{{
                    commission.chairs[0].name }}</a>
                </p>
            </div>
        </div>
        <a href="/sessions/56/meetings/c{{ commission.meeting_id }}/"
           class="card-section padded flex space-between align-center">
            <p data-i18n="seeMeetingDetails">seeMeetingDetails</p>
            {% lucide "chevron-right" %}
        </a>
    </div>
</div>

<div class="swipe-indicator">
    <span class="dot neutral active"></span>
    <span class="dot neutral"></span>
    <span class="dot neutral"></span>
</div>

<!-- INSTAGRAM FOLLOW CARD -->
<a href="https://instagram.com/partijgedragbe" target="_blank" rel="noopener noreferrer"
   class="card flex-row align-center space-between padding" style="margin-top: 1rem;">
    <div class="flex-row align-items:center gap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <div class="flex-col">
            <p class="bold" data-i18n="instagramFollowTitle">Volg ons op Instagram</p>
            <p data-i18n="instagramFollowSubtitle">Blijf op de hoogte van nieuwe dossiers in het Belgische parlement.</p>
        </div>
    </div>
    {% lucide "chevron-right" %}
</a>

<script>
    const row = document.querySelector('.swipeable-row');
    const dots = document.querySelectorAll('.dot');
    const items = document.querySelectorAll('.swipeable-item');
    row.addEventListener('scroll', () => {
        let index = 0;
        let minDiff = Infinity;

        items.forEach((item, i) => {
            const diff = Math.abs(item.getBoundingClientRect().left - row.getBoundingClientRect().left);
            if (diff < minDiff) {
                minDiff = diff;
                index = i;
            }
        });
        dots.forEach(dot => dot.classList.remove('active'));
        if (dots[index]) dots[index].classList.add('active');
    });
</script>
